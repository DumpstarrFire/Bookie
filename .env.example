# ── Booker Environment Variables ──────────────────────────
# Copy this file to .env and fill in the values

# ── Security (REQUIRED in production) ─────────────────────
SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars

# ── Default Login Credentials ──────────────────────────────
# Set before first run – change password in Settings after login
BOOKER_USERNAME=admin
BOOKER_PASSWORD=booker

# ── Network ────────────────────────────────────────────────
PORT=5000

# ── Limits ─────────────────────────────────────────────────
MAX_UPLOAD_MB=500
